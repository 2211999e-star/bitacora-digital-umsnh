# ============================================================================
# Bitácora Digital (ejemplo de variables de entorno)
#
# Nota:
# - La app funciona como SPA estática (sin build obligatorio).
# - En modo simple (python http.server), estas variables NO se inyectan automáticamente.
# - Para producción, puedes:
#   (1) Pegar valores en index.html (window.SUPABASE_URL / window.SUPABASE_ANON_KEY), o
#   (2) Usar un pipeline/build que lea este .env y genere/injecte los valores.
# ============================================================================

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Credenciales del login local (modo offline/demo)
LOCAL_ADMIN_USERNAME=221199e
LOCAL_ADMIN_PASSWORD=123456789

# Administrador principal (único con permisos críticos)
PRIMARY_ADMIN_EMAIL=221199e@umich.mx

# Settings recomendados (se guardan en DB table settings si Supabase está configurado)
ALLOW_REGISTRATION=true
